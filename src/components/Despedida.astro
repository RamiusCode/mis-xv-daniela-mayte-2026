---
// Despedida.astro
---

<section class="pb-2 pt-8 px-4 relative overflow-hidden">
  <!-- Fondo sutil -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#fffaf5]/30 via-transparent to-[#fff5f5]/30 z-0"></div>

  <div class="max-w-5xl mx-auto relative z-10">
    <div class="max-w-3xl mx-auto text-center">

      <!-- 🌸 FLORES SUPERIORES -->
      <div class="flex justify-center mb-3" id="flores-arriba-ded">
      <img
        src="/imagenes/FlorSeparador.webp"
        alt="Flores decorativas superiores"
        class="w-40 sm:w-56 md:w-64 lg:w-72 h-auto object-contain"
      />
    </div>

      <!-- CARD CONTENEDOR DEL MENSAJE -->
      <div class="relative backdrop-blur-sm bg-white/70 rounded-3xl border border-[#eb8fa3]/20 shadow-lg p-8 md:p-10 lg:p-12" id="card-despedida">
        
        <!-- Brillo superior -->
        <div class="absolute top-0 left-0 right-0 h-1/3 bg-gradient-to-b from-white/30 to-transparent rounded-t-3xl pointer-events-none"></div>

        <!-- Esquinas decorativas -->
        <div class="absolute top-2 left-2 w-12 h-12 border-t-2 border-l-2 border-[#eb8fa3]/30"></div>
        <div class="absolute top-2 right-2 w-12 h-12 border-t-2 border-r-2 border-[#eb8fa3]/30"></div>
        <div class="absolute bottom-2 left-2 w-12 h-12 border-b-2 border-l-2 border-[#eb8fa3]/30"></div>
        <div class="absolute bottom-2 right-2 w-12 h-12 border-b-2 border-r-2 border-[#eb8fa3]/30"></div>

        <div class="relative z-10">

          <!-- MENSAJE PRINCIPAL - TODO EN UN SOLO PÁRRAFO -->
          <div id="mensaje-despedida">
            <p class="font-charm text-xl md:text-xl lg:text-2xl text-[#eb8fa3] leading-relaxed mb-6">
              Con la bendición de Dios y el amor de toda mi familia, <span class="text-[#eb8fa3]">me siento muy feliz</span> de llegar a este momento tan especial de mi vida. Ahora empieza un camino lleno de <span class="text-[#eb8fa3]">sueños e ilusiones</span> que, con mucha fe, humildad y esperanza, deseo cumplir. Quisiera, con inmensa alegría, <span class="text-[#eb8fa3]">compartir este comienzo</span> de esta bella etapa junto a todos ustedes.
            </p>

            <!-- Línea decorativa -->
            <div class="flex items-center justify-center gap-3 my-4" id="linea-decorativa">
              <div class="w-16 h-[1px] bg-gradient-to-r from-transparent to-[#eb8fa3]"></div>
              <svg class="w-6 h-6 text-[#eb8fa3]" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
              <div class="w-16 h-[1px] bg-gradient-to-l from-transparent to-[#eb8fa3]"></div>
            </div>
          </div>

          <!-- SECCIÓN CONFIRMAR ASISTENCIA -->
          <div id="seccion-confirmar" class="mt-2">
            
            <!-- Texto de invitación a confirmar -->
            <p class="font-charm text-xl md:text-xl text-[#eb8fa3] leading-relaxed mb-2" id="texto-confirmar">
              Tu presencia es muy importante para mí. Por favor, <span class="text-[#eb8fa3]">confirma tu asistencia</span> para compartir juntos este día tan especial.
            </p>

            <!-- TEXTO DE CONFIRMAR ASISTENCIA -->
            <p class="font-charm pt-10 text-xl md:text-3xl lg:text-4xl text-[#eb8fa3] font-bold mb-8" id="mensaje-confirmar">
              Por favor, haz clic para confirmar asistencia
            </p>

              <!-- BOTÓN MADRE -->
            <div class="flex flex-col items-center gap-1" id="boton-confirmar-madre">
              <p class="font-charm text-base text-[#eb8fa3] font-semibold">Carmen Rojas</p>
              <a
                href="https://wa.me/59173658696?text=Me%20complace%20confirmar%20mi%20asistencia%20para%20los%2015%20a%C3%B1os%20de%20Daniela%20Mayte.%20Nos%20vemos%20el%20s%C3%A1bado%2020%20de%20junio%2C%20estar%C3%A9%20sin%20falta"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 px-8 py-3 md:px-10 md:py-4 bg-[#eb8fa3] rounded-full shadow-md hover:shadow-lg hover:bg-[#d97d91] transition-all duration-300"
              >
                <svg class="w-6 h-6 text-white flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                </svg>
                <span class="font-charm text-base md:text-lg text-white font-semibold">Confirmar Asistencia</span>
              </a>
            </div>

            <!-- BOTÓN QUINCEAÑERA -->
            <div class="flex flex-col items-center gap-1 pt-6" id="boton-confirmar-quince">
              <p class="font-charm text-base text-[#eb8fa3] font-semibold">Daniela Castro</p>
              <a
                href="https://wa.me/59176832347?text=Me%20complace%20confirmar%20mi%20asistencia%20para%20los%2015%20a%C3%B1os%20de%20Daniela%20Mayte.%20Nos%20vemos%20el%20s%C3%A1bado%2020%20de%20junio%2C%20estar%C3%A9%20sin%20falta"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 px-8 py-3 md:px-10 md:py-4 bg-[#eb8fa3] rounded-full shadow-md hover:shadow-lg hover:bg-[#d97d91] transition-all duration-300"
              >
                <svg class="w-6 h-6 text-white flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                </svg>
                <span class="font-charm text-base md:text-lg text-white font-semibold">Confirmar Asistencia</span>
              </a>
            </div>


            <!-- MENSAJE FINAL -->
            <p class="font-charm pt-10 text-2xl md:text-3xl lg:text-4xl text-[#D4AF37] font-bold mb-8" id="mensaje-final">
              ¡Los espero con mucho cariño!
            </p>
          </div>

        </div>

        <!-- Resplandor del card -->
        <div class="absolute -inset-1 bg-gradient-to-br from-[#eb8fa3]/5 via-transparent to-[#D4AF37]/5 rounded-3xl blur-xl -z-10"></div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== 'undefined') {
    document.addEventListener("DOMContentLoaded", () => {
      // Estado inicial
      gsap.set("#flores-arriba-ded",       { opacity: 0, y: -30 });
      gsap.set("#card-despedida",          { opacity: 0, y: 40, scale: 0.95 });
      gsap.set("#mensaje-despedida",       { opacity: 0, y: 20 });
      gsap.set("#linea-decorativa",        { opacity: 0, scaleX: 0 });
      gsap.set("#texto-confirmar",         { opacity: 0, y: 20 });
      gsap.set("#mensaje-confirmar",       { opacity: 0, y: 20 });
      gsap.set("#boton-confirmar-madre",   { opacity: 0, y: 20 });
      gsap.set("#boton-confirmar-quince",  { opacity: 0, y: 20 });
      gsap.set("#mensaje-final",           { opacity: 0, y: 20 });

      ScrollTrigger.create({
        trigger: "#card-despedida",
        start: "top 85%",
        end: "top 20%",
        onEnter: () => {
          gsap.to("#flores-arriba-ded",      { opacity: 1, y: 0,     duration: 0.7, ease: "power2.out" });
          gsap.to("#card-despedida",         { opacity: 1, y: 0, scale: 1, duration: 0.7, ease: "power3.out" });
          gsap.to("#mensaje-despedida",      { opacity: 1, y: 0,     duration: 0.7, ease: "power2.out" });
          gsap.to("#linea-decorativa",       { opacity: 1, scaleX: 1,duration: 0.7, ease: "power2.out" });
          gsap.to("#texto-confirmar",        { opacity: 1, y: 0,     duration: 0.7, ease: "power2.out" });
          gsap.to("#mensaje-confirmar",      { opacity: 1, y: 0,     duration: 0.7, ease: "power2.out" });
          gsap.to("#boton-confirmar-madre",  { opacity: 1, y: 0,     duration: 0.7, ease: "power2.out" });
          gsap.to("#boton-confirmar-quince", { opacity: 1, y: 0,     duration: 0.7, ease: "power2.out" });
          gsap.to("#mensaje-final",          { opacity: 1, y: 0,     duration: 0.7, ease: "power2.out" });

          gsap.to("#linea-decorativa svg", { scale: 1.2, duration: 1.5, ease: "sine.inOut", yoyo: true, repeat: -1, delay: 0.7 });
        },
        onLeaveBack: () => {
          gsap.set("#flores-arriba-ded",       { opacity: 0, y: -30 });
          gsap.set("#card-despedida",          { opacity: 0, y: 40, scale: 0.95 });
          gsap.set("#mensaje-despedida",       { opacity: 0, y: 20 });
          gsap.set("#linea-decorativa",        { opacity: 0, scaleX: 0 });
          gsap.set("#texto-confirmar",         { opacity: 0, y: 20 });
          gsap.set("#mensaje-confirmar",       { opacity: 0, y: 20 });
          gsap.set("#boton-confirmar-madre",   { opacity: 0, y: 20 });
          gsap.set("#boton-confirmar-quince",  { opacity: 0, y: 20 });
          gsap.set("#mensaje-final",           { opacity: 0, y: 20 });
        },
      });

    });
  }
</script>

<style>
  #card-despedida:hover {
    box-shadow: 0 20px 40px rgba(212, 175, 55, 0.15);
    transition: box-shadow 0.5s ease;
  }

  #mensaje-despedida span {
    transition: all 0.3s ease;
  }

  #mensaje-despedida span:hover {
    color: #D4AF37;
    text-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
  }
</style>