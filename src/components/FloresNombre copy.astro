<section class="relative text-black w-full overflow-x-hidden">

    <!-- Flores: decoración de fondo, no ocupan espacio en el layout -->
    <div class="absolute top-0 left-0 right-0 pointer-events-none z-0" id="flores-arriba" style="opacity: 1 !important;">
        <img
            src="/imagenes/FloresArriba.png"
            alt="Flores decorativas"
            class="w-full h-auto object-cover object-center block"
            style="opacity: 1 !important;"
        />
    </div>

    <!-- Todo el contenido encima de las flores -->
    <div class="relative z-10 w-full px-4">
        <div class="flex justify-center w-full">
            <div class="text-center max-w-4xl w-full">

                <!-- Corona en flujo normal -->
                <div class="flex justify-center pt-14 sm:pt-16 md:pt-20 mb-10" id="corona">
                    <img
                        src="/imagenes/Corona.webp"
                        alt="Corona de quinceañera"
                        class="w-32 h-auto sm:w-32 sm:h-32 md:w-36 md:h-36 lg:w-40 lg:h-40 xl:w-44 xl:h-44 object-contain mx-auto"
                    />
                </div>

                <!-- MIS XV AÑOS -->
                <div class="relative text-center z-30 mb-8 w-full" id="titulo-container">
                    <h1
                        class="font-crimson text-2xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl text-[#eb8fa3] font-bold tracking-wider"
                        id="titulo"
                    >
                        MIS XV AÑOS
                    </h1>
                </div>

                <!-- Mariposas + Nombre -->
                <div class="flex items-center justify-center gap-4 sm:gap-8 md:gap-16 lg:gap-24 mb-8 w-full" id="nombre-container">
                    <div id="mariposa-izq" class="flex-shrink-0">
                        <img
                            src="/imagenes/mariposa.png"
                            alt="Mariposa izquierda"
                            class="w-10 h-auto sm:w-8 sm:h-8 md:w-10 md:h-10 lg:w-12 lg:h-12 object-contain"
                        />
                    </div>
                    <h2
                        class="font-great-vibes text-7xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-[#D4AF37] tracking-wide flex-shrink min-w-0"
                        id="nombre-typewriter"
                    >
                    </h2>
                    <div id="mariposa-der" class="flex-shrink-0">
                        <img
                            src="/imagenes/mariposa.png"
                            alt="Mariposa derecha"
                            class="w-10 h-auto sm:w-8 sm:h-8 md:w-10 md:h-10 lg:w-12 lg:h-12 object-contain scale-x-[-1]"
                        />
                    </div>
                </div>

                <!-- Foto + flores laterales -->
                <div class="relative w-full overflow-visible" id="foto-container">
                    <div id="flores-foto-izq" class="absolute -left-4 sm:left-0 top-32 sm:top-24 md:top-20 lg:top-16 flex-shrink-0 z-30">
                        <img
                            src="/imagenes/FlorLateral.webp"
                            alt="Flores izquierda"
                            class="w-12 h-auto sm:w-24 md:w-32 lg:w-40 object-contain"
                        />
                    </div>
                    <div id="flores-foto-der" class="absolute -right-4 sm:right-0 top-32 sm:top-24 md:top-20 lg:top-16 flex-shrink-0 z-30">
                        <img
                            src="/imagenes/FlorLateral.webp"
                            alt="Flores derecha"
                            class="w-12 h-auto sm:w-24 md:w-32 lg:w-40 object-contain scale-x-[-1]"
                        />
                    </div>
                    <div class="relative flex justify-center">
                        <img
                            src="/imagenes/rayo.png"
                            alt="Foto de quinceañera"
                            class="w-full max-w-[65vw] h-auto sm:max-w-[55vw] md:max-w-[45vw] lg:max-w-[35vw] xl:max-w-[30vw] object-contain"
                            id="foto-quinceañera"
                        />
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        // FLORES ARRIBA - Sin animación para mantener opacidad completa
        gsap.set("#flores-arriba", { clearProps: "all" });

        // CORONA - Zoom in
        gsap.fromTo(
            "#corona",
            { opacity: 0, scale: 0.5 },
            {
                opacity: 1,
                scale: 1,
                duration: 1.2,
                ease: "back.out(1.2)",
                delay: 0.3,
            },
        );

        // TÍTULO - Fade in de arriba
        gsap.fromTo(
            "#titulo",
            { opacity: 0, y: 30 },
            { opacity: 1, y: 0, duration: 1, ease: "power2.out", delay: 0.5 },
        );

        // MARIPOSA IZQUIERDA - Llega de la izquierda
        gsap.fromTo(
            "#mariposa-izq",
            { opacity: 0, x: -50, y: 20, rotation: -15, scale: 0.8 },
            {
                opacity: 1,
                x: 0,
                y: 0,
                rotation: 0,
                scale: 1,
                duration: 4,
                ease: "power2.out",
            },
        );

        // MARIPOSA IZQUIERDA - vuelo
        gsap.to("#mariposa-izq", { y: -18, duration: 2,   ease: "sine.inOut", yoyo: true, repeat: -1, delay: 1.5 });
        gsap.to("#mariposa-izq", { x: 10,  duration: 3.2, ease: "sine.inOut", yoyo: true, repeat: -1, delay: 1.5 });
        gsap.to("#mariposa-izq", { rotation: 12,  duration: 2.6, ease: "sine.inOut",  yoyo: true, repeat: -1, delay: 1.5 });
        gsap.to("#mariposa-izq", { scaleX: 0.45,  duration: 0.35, ease: "power1.inOut", yoyo: true, repeat: -1, delay: 2 });

        // MARIPOSA DERECHA - Llega de la derecha
        gsap.fromTo(
            "#mariposa-der",
            { opacity: 0, x: 50, y: 20, rotation: 15, scale: 0.8 },
            {
                opacity: 1,
                x: 0,
                y: 0,
                rotation: 0,
                scale: 1,
                duration: 4,
                ease: "power2.out",
            },
        );

        // MARIPOSA DERECHA - vuelo
        gsap.to("#mariposa-der", { y: -14, duration: 2.4, ease: "sine.inOut", yoyo: true, repeat: -1, delay: 1.8 });
        gsap.to("#mariposa-der", { x: -10, duration: 2.8, ease: "sine.inOut", yoyo: true, repeat: -1, delay: 1.8 });
        gsap.to("#mariposa-der", { rotation: -12, duration: 3,    ease: "sine.inOut",  yoyo: true, repeat: -1, delay: 1.8 });
        gsap.to("#mariposa-der", { scaleX: 0.45,  duration: 0.4,  ease: "power1.inOut", yoyo: true, repeat: -1, delay: 2.3 });

        // FLORES IZQUIERDA - Salen de la izquierda
        gsap.fromTo(
            "#flores-foto-izq",
            { opacity: 0, x: -150 },
            { opacity: 1, x: 0, duration: 1.5, ease: "power2.out", delay: 0.7 },
        );

        // FLORES DERECHA - Salen de la derecha
        gsap.fromTo(
            "#flores-foto-der",
            { opacity: 0, x: 150 },
            { opacity: 1, x: 0, duration: 1.5, ease: "power2.out", delay: 0.7 },
        );

        // NOMBRE - Efecto cascada letra por letra
        function nombreCascadaElegante() {
            const texto = "Daniela Mayte";
            const contenedor = document.getElementById("nombre-typewriter");
            if (!contenedor) return;

            contenedor.innerHTML = texto
                .split("")
                .map(
                    (letra, index) =>
                        `<span class="letra-cascada" style="
                            --i: ${index};
                            opacity: 0; 
                            display: inline-block; 
                            transform: translateY(30px) scale(0.8);
                            filter: blur(2px);
                        ">${letra}</span>`,
                )
                .join("");

            gsap.to(".letra-cascada", {
                opacity: 1,
                y: 0,
                scale: 1,
                filter: "blur(0px)",
                duration: 0.8,
                ease: "back.out(1.6)",
                stagger: { each: 0.12, from: "start" },
            });
        }

        // IMAGEN PRINCIPAL - Fade in con zoom
        gsap.fromTo(
            "#foto-container",
            { opacity: 0, scale: 0.8, y: 30 },
            { opacity: 1, scale: 1, y: 0, duration: 1.2, ease: "power2.out" },
        );

        nombreCascadaElegante();
    });
</script>

<style>
    /* Forzar opacidad completa en flores superiores */
    #flores-arriba,
    #flores-arriba img {
        opacity: 1 !important;
    }

    .letra-cascada {
        transition: all 0.3s ease;
        will-change: transform, opacity, filter;
        position: relative;
    }

    .letra-cascada:hover {
        transform: translateY(-3px) scale(1.05) !important;
        text-shadow: 0 0 12px rgba(78, 104, 75, 0.5) !important;
    }
</style>
